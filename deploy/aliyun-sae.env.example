# Copy this file to a local, untracked env file before deploying:
#   cp deploy/aliyun-sae.env.example .env.aliyun-sae
#   source .env.aliyun-sae
#
# Do not commit real AccessKeys, registry passwords, or private endpoints.

# Alibaba Cloud CLI profile and region.
export ALIYUN_PROFILE="onsite-scheduler"
export ALIYUN_REGION="cn-shanghai"

# ACR image target.
# Create the namespace/repository in Alibaba Cloud Container Registry first,
# or point these values to an existing private repository.
export ALIYUN_ACR_REGISTRY="registry.cn-shanghai.aliyuncs.com"
export ALIYUN_ACR_NAMESPACE="your-acr-namespace"
export ALIYUN_ACR_REPO="onsite-inspection-scheduler"

# Optional: provide registry credentials for docker login.
# Prefer a RAM user or ACR-specific password with the minimum required scope.
# export ALIYUN_ACR_USERNAME="your-registry-username"
# export ALIYUN_ACR_PASSWORD="your-registry-password"

# SAE application target.
export ALIYUN_SAE_APP_NAME="onsite-inspection-scheduler"

# Existing app update mode:
# export ALIYUN_SAE_APP_ID="your-sae-app-id"

# New app create mode:
# Find namespace IDs with:
#   aliyun sae DescribeNamespaceList --ContainCustom true --region "$ALIYUN_REGION" --profile "$ALIYUN_PROFILE"
# export ALIYUN_SAE_NAMESPACE_ID="your-sae-namespace-id"

# Runtime sizing.
export ALIYUN_SAE_CPU="1000"
export ALIYUN_SAE_MEMORY="2048"
export ALIYUN_SAE_REPLICAS="1"

# Data safety. Required by scripts/deploy-aliyun-sae.sh deploy.
# Generate with: openssl rand -hex 32
export WORKSPACE_ADMIN_TOKEN="replace-with-strong-random-token"
export WORKSPACE_STATE_PATH="/data/workspace-state.json"

# Image build options.
export DOCKER_PLATFORM="linux/amd64"
# export ALIYUN_IMAGE_TAG="manual-tag"
